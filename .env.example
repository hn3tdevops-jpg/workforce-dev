# Environment variables for Workforce Developer Hub

# Flask secret key (CHANGE THIS IN PRODUCTION)
SECRET_KEY=change-me-in-production

# Database URL (default: SQLite in instance/)
# DATABASE_URL=sqlite:///devhub.db
# DATABASE_URL=postgresql://user:pass@localhost/devhub

# Feature flags
DEVHUB_ENABLE_SCRIPT_EXECUTION=false
DEVHUB_ENABLE_PACKAGE_INSTALL=false

# Workspace roots for file scanning (colon-separated paths)
DEVHUB_WORKSPACE_ROOTS=/path/to/project1:/path/to/project2

# Flask settings
FLASK_APP=wsgi:app
FLASK_ENV=development
